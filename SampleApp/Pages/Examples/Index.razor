@page "/examples"
@page "/"
@using global::BlazorTUI.TUI
@using Color = System.Drawing.Color
@inject NavigationManager Navigation

<PageTitle>BlazorTUI examples</PageTitle>

<BlazorTUI.BlazorTUI
    screen="@screen"
    AriaLabel="BlazorTUI example catalog"
    AriaDescription="Choose an example and press Enter or Space to open it." />

@code {
    private static readonly ExampleDestination[] Destinations =
    {
        new("controlsExample", "Controls and events", "Inputs and callbacks", "/examples/controls-events"),
        new("additionalInputsExample", "Additional inputs", "Search, masks, multi", "/examples/additional-inputs"),
        new("validationExample", "Form validation", "Required fields", "/examples/form-validation"),
        new("dataFormExample", "DataForm", "Model-bound fields", "/examples/data-form"),
        new("gridViewExample", "GridView", "Advanced data grid", "/examples/grid-view"),
        new("dataVisualizationsExample", "Data visualizations", "Charts and metrics", "/examples/data-visualizations"),
        new("dialogsExample", "Dialogs and menus", "Modal interactions", "/examples/dialogs-menus"),
        new("imagesExample", "Images", "PictureBox rendering", "/examples/images"),
        new("tabsExample", "TabControl", "Tabbed layouts", "/examples/tabs"),
        new("treeExample", "TreeView", "Hierarchical data", "/examples/tree-view"),
        new("sliderExample", "Slider", "Numeric ranges", "/examples/sliders"),
        new("splitExample", "SplitPanel", "Resizable panes", "/examples/split-panels"),
        new("stackExample", "StackPanel", "Linear layout", "/examples/stack-panel"),
        new("gridPanelExample", "GridPanel", "Rows and columns", "/examples/grid-panel"),
        new("dockPanelExample", "DockPanel", "Docked regions", "/examples/dock-panel"),
        new("wrapPanelExample", "WrapPanel", "Flow layout", "/examples/wrap-panel"),
        new("scrollViewerExample", "ScrollViewer", "Clipped content", "/examples/scroll-viewer"),
        new("calendarExample", "Calendar", "Month view", "/examples/calendar"),
        new("datePickerExample", "DatePicker", "Popup calendar", "/examples/date-picker"),
        new("dateRangePickerExample", "DateRangePicker", "Date ranges", "/examples/date-range-picker"),
        new("monthPickerExample", "MonthPicker", "Popup months", "/examples/month-picker"),
        new("breadcrumbExample", "Breadcrumb", "Hierarchical navigation", "/examples/breadcrumbs"),
        new("themesExample", "Themes", "Runtime palettes", "/examples/themes"),
        new("transientUiExample", "Transient UI", "Menus and overlays", "/examples/transient-ui"),
        new("statePersistenceExample", "State persistence", "Save/restore state", "/examples/state-persistence"),
        new("showcaseExample", "Complete showcase", "All controls", "/examples/showcase")
    };

    private Screen screen = null!;

    protected override void OnInitialized()
    {
        screen = new Screen(80, 38);

        var frame = new Frame(
            "examplesFrame", "BLAZORTUI EXAMPLES", 1, 2, 78, 34,
            Frame.BorderStyle.Line, Color.Yellow, Color.DarkBlue);
        screen.TopContainer.AddContainer(frame);

        frame.AddControl(new Label(
            "catalogInstructions", "Choose an example with Tab and press Enter.",
            3, 2, 44, Color.White, Color.DarkBlue));

        frame.AddControl(new Label(
            "catalogSubtitle", "Focused pages show one feature; showcase displays all controls.",
            3, 3, 72, Color.Cyan, Color.DarkBlue));

        for (int index = 0; index < Destinations.Length; index++)
        {
            ExampleDestination destination = Destinations[index];
            short column = (short)(3 + (index / 9) * 25);
            short row = (short)(5 + (index % 9) * 3);
            var button = new Button(
                destination.ControlName, destination.Title,
                column, row, 21, Color.Yellow, Color.Black);
            button.Clicked += (_, _) => Navigation.NavigateTo(destination.Route);
            frame.AddControl(button);

            frame.AddControl(new Label(
                $"{destination.ControlName}Description", destination.Description,
                column, (short)(row + 1), 21, Color.Cyan, Color.DarkBlue));
        }

        frame.AddControl(new Label(
            "catalogFooter", "Root page: this catalog. Mouse clicks supported.",
            3, 32, 72, Color.White, Color.DarkBlue));

        screen.SetFocus(Destinations[0].ControlName);
    }

    private sealed record ExampleDestination(
        string ControlName,
        string Title,
        string Description,
        string Route);
}
