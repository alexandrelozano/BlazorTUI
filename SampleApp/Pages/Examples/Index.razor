@page "/examples"
@using global::BlazorTUI.TUI
@using Color = System.Drawing.Color
@inject NavigationManager Navigation

<PageTitle>BlazorTUI examples</PageTitle>

<BlazorTUI.BlazorTUI
    screen="@screen"
    AriaLabel="BlazorTUI example catalog"
    AriaDescription="Choose an example and press Enter or Space to open it." />

@code {
    private static readonly ExampleDestination[] Destinations =
    {
        new("controlsExample", "Controls and events", "Inputs and callbacks", "/examples/controls-events"),
        new("dialogsExample", "Dialogs and menus", "Modal interactions", "/examples/dialogs-menus"),
        new("imagesExample", "Images", "PictureBox rendering", "/examples/images"),
        new("tabsExample", "TabControl", "Tabbed layouts", "/examples/tabs"),
        new("treeExample", "TreeView", "Hierarchical data", "/examples/tree-view"),
        new("sliderExample", "Slider", "Numeric ranges", "/examples/sliders"),
        new("splitExample", "SplitPanel", "Resizable panes", "/examples/split-panels"),
        new("breadcrumbExample", "Breadcrumb", "Hierarchical navigation", "/examples/breadcrumbs"),
        new("showcaseExample", "Complete showcase", "All controls", "/")
    };

    private Screen screen = null!;

    protected override void OnInitialized()
    {
        screen = new Screen(60, 30);

        var frame = new Frame(
            "examplesFrame", "BLAZORTUI EXAMPLES", 3, 3, 54, 24,
            Frame.BorderStyle.Line, Color.Yellow, Color.DarkBlue);
        screen.TopContainer.AddContainer(frame);

        frame.AddControl(new Label(
            "catalogInstructions", "Choose an example with Tab and press Enter.",
            3, 2, 42, Color.White, Color.DarkBlue));

        for (int index = 0; index < Destinations.Length; index++)
        {
            ExampleDestination destination = Destinations[index];
            short row = (short)(5 + index * 2);
            var button = new Button(
                destination.ControlName, destination.Title,
                3, row, 23, Color.Yellow, Color.Black);
            button.Clicked += (_, _) => Navigation.NavigateTo(destination.Route);
            frame.AddControl(button);

            frame.AddControl(new Label(
                $"{destination.ControlName}Description", destination.Description,
                28, row, 22, Color.Cyan, Color.DarkBlue));
        }

        frame.AddControl(new Label(
            "catalogFooter", "Mouse clicks are also supported.",
            3, 22, 36, Color.White, Color.DarkBlue));

        screen.SetFocus(Destinations[0].ControlName);
    }

    private sealed record ExampleDestination(
        string ControlName,
        string Title,
        string Description,
        string Route);
}
