@page "/examples/dialogs-menus"
@using global::BlazorTUI.TUI
@using Color = System.Drawing.Color

<PageTitle>Dialogs and menus example</PageTitle>

<BlazorTUI.BlazorTUI screen="@screen" />

@code {
    private Screen screen = null!;

    protected override void OnInitialized()
    {
        screen = new Screen(60, 30);

        var menuBar = new MenuBar(Color.White, Color.SteelBlue, screen);
        var actionsMenu = new Menu("Actions", 'A');

        var showDialogItem = new MenuItem("Open dialog", MenuItem.MenuItemType.Item, 'O');
        showDialogItem.Clicked += (_, _) => ShowDialog();
        actionsMenu.AddItem(showDialogItem);

        var showMessageItem = new MenuItem("Show message", MenuItem.MenuItemType.Item, 'S');
        showMessageItem.Clicked += (_, _) => ShowMessage();
        actionsMenu.AddItem(showMessageItem);

        menuBar.AddMenu(actionsMenu);
        screen.MenuBar = menuBar;

        var frame = new Frame(
            "menuFrame", "DIALOGS AND MENUS", 8, 6, 44, 16,
            Frame.BorderStyle.Line, Color.Yellow, Color.DarkBlue);
        screen.TopContainer.AddContainer(frame);

        frame.AddControl(new Label(
            "instructions", "Use Alt+A or activate a button:", 4, 3, 34,
            Color.White, Color.DarkBlue));

        var dialogButton = new Button(
            "dialogButton", "Open dialog", 6, 7, 14, Color.White, Color.DarkGreen);
        dialogButton.Clicked += (_, _) => ShowDialog();
        frame.AddControl(dialogButton);

        var messageButton = new Button(
            "messageButton", "Message box", 24, 7, 14, Color.White, Color.DarkMagenta);
        messageButton.Clicked += (_, _) => ShowMessage();
        frame.AddControl(messageButton);

        screen.SetFocus("dialogButton");
    }

    private void ShowDialog()
    {
        var dialog = new Dialog(
            "exampleDialog", "CUSTOM DIALOG", 34, 10, BorderStyle.Line,
            Color.Yellow, Color.DarkGreen, screen);

        dialog.AddControl(new Label(
            "dialogText", "This is a modal Dialog.", 5, 3, 24,
            Color.White, Color.DarkGreen));

        var closeButton = new Button(
            "closeDialog", "Close", 12, 6, 10, Color.White, Color.DarkBlue);
        closeButton.Clicked += (_, _) => dialog.Close();
        dialog.AddControl(closeButton);

        dialog.Show();
        screen.SetFocus("closeDialog");
    }

    private void ShowMessage()
    {
        var message = new MessageBox(
            "MessageBox handles common button layouts.", "MESSAGE BOX",
            MessageBox.Buttons.OKCancel, BorderStyle.Line,
            Color.White, Color.DarkMagenta, screen);
        message.Show();
    }
}
