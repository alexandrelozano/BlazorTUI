@page "/examples/controls-events"
@using global::BlazorTUI.TUI
@using Color = System.Drawing.Color

<PageTitle>Controls and events example</PageTitle>

<BlazorTUI.BlazorTUI screen="@screen" />

@code {
    private Screen screen = null!;
    private TextBox nameInput = null!;
    private CheckBox includeDetails = null!;
    private StatusBar eventStatus = null!;

    protected override void OnInitialized()
    {
        screen = new Screen(60, 30);

        var frame = new Frame(
            "formFrame", "CONTROLS AND EVENTS", 8, 4, 44, 22,
            Frame.BorderStyle.Line, Color.Yellow, Color.DarkBlue);
        screen.TopContainer.AddContainer(frame);

        frame.AddControl(new Label(
            "nameLabel", "Name:", 3, 3, 10, Color.White, Color.DarkBlue));

        nameInput = new TextBox(
            "nameInput", "", 14, 3, 22, Color.Yellow, Color.Black);
        nameInput.GotFocus += (_, _) => eventStatus.Value = "Name focused";
        nameInput.LostFocus += (_, _) => eventStatus.Value = "Name lost focus";
        frame.AddControl(nameInput);

        frame.AddControl(new Label(
            "passwordLabel", "Password:", 3, 6, 10, Color.White, Color.DarkBlue));

        var passwordInput = new PasswordBox(
            "passwordInput", "secret", 14, 6, 22, Color.Yellow, Color.Black);
        frame.AddControl(passwordInput);

        frame.AddControl(new Label(
            "priorityLabel", "Priority:", 3, 9, 10, Color.White, Color.DarkBlue));

        var priorityInput = new ComboBox(
            "priorityInput",
            new[] { "Low", "Normal", "High", "Urgent" },
            14, 9, 22, Color.Yellow, Color.Black,
            selectedIndex: 1,
            maxDropDownItems: 4);
        priorityInput.SelectedIndexChanged += (_, _) =>
            eventStatus.Value = $"Priority: {priorityInput.SelectedItem}";
        frame.AddControl(priorityInput);

        includeDetails = new CheckBox(
            "includeDetails", "Include details", 14, 14, 22,
            Color.Yellow, Color.DarkBlue);
        includeDetails.Clicked += (_, _) => eventStatus.Value = "Checkbox changed";
        frame.AddControl(includeDetails);

        var greetButton = new Button(
            "greetButton", "Greet", 14, 16, 12, Color.White, Color.DarkGreen);
        greetButton.Clicked += (_, _) => ShowGreeting();
        frame.AddControl(greetButton);

        eventStatus = new StatusBar(
            "eventStatus", "Ready", 2, 20, 40, Color.Black, Color.Cyan)
        {
            Separator = "  "
        };
        eventStatus.AddItem("tabHint", "Tab focus");
        eventStatus.AddItem("enterHint", "Enter action");
        frame.AddControl(eventStatus);

        screen.SetFocus("nameInput");
    }

    private void ShowGreeting()
    {
        string name = string.IsNullOrWhiteSpace(nameInput.Value) ? "guest" : nameInput.Value;
        string suffix = includeDetails.Value ? " Details enabled." : "";

        var message = new MessageBox(
            $"Hello, {name}!{suffix}", "EVENT RESULT", MessageBox.Buttons.OKOnly,
            BorderStyle.Line, Color.White, Color.DarkGreen, screen);
        message.Show();
    }
}
