        var multiSelect = new MultiSelectComboBox(
            "consumerMultiSelect",
            new[] { "Online", "VIP", "Late" },
            0, 0, 16,
            System.Drawing.Color.White,
            System.Drawing.Color.Black,
            selectedItems: new[] { "Online" });
        multiSelect.SelectionChanged += (_, args) => _ = args.Item;
        multiSelect.SelectItem("VIP");
        multiSelect.DeselectItem("Online");
        terminal.TopContainer.AddControl(multiSelect);
        terminal.SetFocus("priority");
        TuiScreenState state = terminal.ExportState();
        _ = state.SchemaVersion;
        state.SetPayload("route", "/consumer");
        _ = state.TryGetPayload("route", out string _);
        state.SetProtectedPayload("secret", "payload", value => Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(value)));
        _ = state.TryGetProtectedPayload(
            "secret",
            value => System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(value)),
            out string _);
        string serializedState = terminal.ExportStateJson();
        terminal.RestoreState(state);
        terminal.RestoreState(
            state,
            new TuiStateRestoreOptions
            {
                SuppressEvents = true,
                RestoreFocus = false,
                ControlNames = new[] { "priority" },
                Migrations = new[]
                {
                    new TuiStateMigration(0, TuiScreenState.CurrentSchemaVersion, migratedState => migratedState)
                }
            });
        terminal.RestoreStateJson(serializedState);
        terminal.RestoreStateJson(serializedState, new TuiStateRestoreOptions { RestoreContainers = false });
        return terminal;
    }

    private static Task<bool> ConfirmWithDialogServiceAsync(Screen terminal)
        => terminal.DialogService.ConfirmAsync("Continue?", "Confirm");

    private sealed class SmokeFormModel
    {
        public string Name { get; set; } = "";

        public string Priority { get; set; } = "";

        public bool Notify { get; set; }
    }
}
