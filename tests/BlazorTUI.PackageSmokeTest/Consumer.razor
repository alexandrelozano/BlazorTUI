@using global::BlazorTUI.TUI

<BlazorTUI.BlazorTUI screen="@terminal" />

@code {
    private readonly Screen terminal = CreateTerminal();

    private static Screen CreateTerminal()
    {
        var terminal = new Screen(20, 10);
        var button = new Button(
            "save", "Save", 2, 2, 8,
            System.Drawing.Color.White, System.Drawing.Color.DarkGreen);
        var input = new TextBox(
            "name", "Alex", 2, 1, 10,
            System.Drawing.Color.White, System.Drawing.Color.Black);
        var password = new PasswordBox(
            "password", "secret", 2, 3, 10,
            System.Drawing.Color.White, System.Drawing.Color.Black);
        IClipboardControl clipboard = input;
        IClipboardPermissions passwordClipboard = password;
        IUndoableControl editHistory = input;
        clipboard.SelectAll();
        passwordClipboard.AllowPaste = true;
        editHistory.ClearHistory();
        button.Clicked += (_, _) => { };
        terminal.TopContainer.AddControl(input);
        terminal.TopContainer.AddControl(password);
        terminal.TopContainer.AddControl(button);
        var priority = new ComboBox(
            "priority", new[] { "Low", "High" }, 11, 1, 9,
            System.Drawing.Color.White, System.Drawing.Color.Black);
        priority.SelectedIndexChanged += (_, _) => { };
        priority.SelectItem("High");
        terminal.TopContainer.AddControl(priority);
        var tabs = new TabControl(
            "tabs", 0, 5, 20, 5,
            System.Drawing.Color.White, System.Drawing.Color.DarkBlue);
        terminal.TopContainer.AddContainer(tabs);
        TabPage page = tabs.AddTab("generalTab", "General");
        page.AddControl(new Label(
            "tabLabel", "Tabs work", 1, 1, 10,
            System.Drawing.Color.White, System.Drawing.Color.DarkBlue));
        return terminal;
    }
}
