@using global::BlazorTUI.TUI

<BlazorTUI.BlazorTUI screen="@terminal" />

@code {
    private readonly Screen terminal = CreateTerminal();

    private static Screen CreateTerminal()
    {
        var terminal = new Screen(24, 12);
        var button = new Button(
            "save", "Save", 2, 2, 8,
            System.Drawing.Color.White, System.Drawing.Color.DarkGreen);
        var input = new TextBox(
            "name", "Alex", 2, 1, 10,
            System.Drawing.Color.White, System.Drawing.Color.Black);
        var password = new PasswordBox(
            "password", "secret", 2, 3, 10,
            System.Drawing.Color.White, System.Drawing.Color.Black);
        IClipboardControl clipboard = input;
        IClipboardPermissions passwordClipboard = password;
        IUndoableControl editHistory = input;
        clipboard.SelectAll();
        passwordClipboard.AllowPaste = true;
        editHistory.ClearHistory();
        button.Clicked += (_, _) => { };
        terminal.TopContainer.AddControl(input);
        terminal.TopContainer.AddControl(password);
        terminal.TopContainer.AddControl(button);
        var priority = new ComboBox(
            "priority", new[] { "Low", "High" }, 11, 1, 9,
            System.Drawing.Color.White, System.Drawing.Color.Black);
        priority.SelectedIndexChanged += (_, _) => { };
        priority.SelectItem("High");
        terminal.TopContainer.AddControl(priority);
        var contact = new RadioGroup(
            "contact",
            new[]
            {
                new RadioGroupOption("emailContact", "Email", "email"),
                new RadioGroupOption("phoneContact", "Phone", "phone")
            },
            0, 4, 20,
            System.Drawing.Color.White, System.Drawing.Color.Black,
            selectedIndex: 0,
            RadioGroupOrientation.Horizontal);
        contact.SelectionChanged += (_, args) => _ = args.SelectedOption?.Value;
        contact.SelectValue("phone");
        terminal.TopContainer.AddControl(contact);
        var slider = new Slider(
            "volume",
            minimum: 0,
            maximum: 100,
            value: 50,
            step: 10,
            X: 11,
            Y: 3,
            length: 9,
            SliderOrientation.Horizontal,
            System.Drawing.Color.White,
            System.Drawing.Color.Black,
            largeChange: 20);
        slider.ValueChanged += (_, args) => _ = args.Value;
        slider.Increase();
        terminal.TopContainer.AddControl(slider);
        var status = new StatusBar(
            "status", "Ready", 0, 5, 20,
            System.Drawing.Color.Black, System.Drawing.Color.Gray);
        status.AddItem("help", "F1 Help");
        status.Value = "Saved";
        terminal.TopContainer.AddControl(status);
        var split = new SplitPanel(
            "split", 0, 6, 20, 2,
            SplitPanelOrientation.Vertical, 9,
            System.Drawing.Color.White, System.Drawing.Color.DarkBlue);
        split.FirstPanel.AddControl(new Label(
            "splitLeft", "Left", 0, 0, 4,
            System.Drawing.Color.White, System.Drawing.Color.DarkBlue));
        split.SecondPanel.AddControl(new Label(
            "splitRight", "Right", 0, 0, 5,
            System.Drawing.Color.White, System.Drawing.Color.DarkBlue));
        split.MoveSplitter(1);
        terminal.TopContainer.AddContainer(split);
        var tabs = new TabControl(
            "tabs", 0, 8, 20, 4,
            System.Drawing.Color.White, System.Drawing.Color.DarkBlue);
        terminal.TopContainer.AddContainer(tabs);
        TabPage page = tabs.AddTab("generalTab", "General");
        var tree = new TreeView(
            "consumerTree", 1, 0, 16, 2,
            System.Drawing.Color.White, System.Drawing.Color.DarkBlue);
        TreeNode root = tree.AddNode("rootNode", "Root", true);
        root.AddNode("childNode", "Child");
        tree.SelectedNodeChanged += (_, args) => _ = args.SelectedNode?.Name;
        page.AddControl(tree);
        return terminal;
    }
}
