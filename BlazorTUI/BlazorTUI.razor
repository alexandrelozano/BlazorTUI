@using global::BlazorTUI.TUI

@implements IDisposable

<div class="containerfs">
    <div tabindex="0" class="gridfs" style="@GridCssVariables" @onkeydown="HandleKeyDown" @onkeydown:preventDefault>
        @foreach (Row row in screen.rows)
        {
            <TuiRow @key="row" Row="row" CellClicked="OnClickCell" />
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public Screen screen { get; set; } = null!;

    private readonly System.Timers.Timer _timer = new(250);
    private Screen? _renderedScreen;
    private long _renderedRevision = -1;
    private bool _disposed;

    private string GridCssVariables
    {
        get
        {
            double width = Math.Max(1d, screen.width);
            double height = Math.Max(1d, screen.height);
            double aspectRatio = width / (height * 2);
            double inverseAspectRatio = 1 / aspectRatio;
            double fontSize = 100 / height;

            return FormattableString.Invariant($"--tui-columns:{screen.width}; --tui-rows:{screen.height}; --tui-width-from-height:{aspectRatio * 100}cqh; --tui-height-from-width:{inverseAspectRatio * 100}cqw; --tui-font-size:{fontSize}cqh;");
        }
    }

    protected override void OnInitialized()
    {
        _timer.Elapsed += TimeElapsed;
        _timer.AutoReset = true;
        _timer.Enabled = true;
    }

    protected override void OnParametersSet()
        => screen.Render();

    protected override bool ShouldRender()
        => !ReferenceEquals(_renderedScreen, screen) || _renderedRevision != screen.Revision;

    protected override void OnAfterRender(bool firstRender)
    {
        _renderedScreen = screen;
        _renderedRevision = screen.Revision;
    }

    private void TimeElapsed(object? sender, System.Timers.ElapsedEventArgs e)
        => _ = InvokeAsync(RefreshFromTimer);

    private void RefreshFromTimer()
    {
        if (_disposed)
            return;

        long previousRevision = screen.Revision;
        screen.Render();

        if (screen.Revision != previousRevision)
            StateHasChanged();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        screen.KeyDown(e.Key, e.ShiftKey);
        screen.Render();
    }

    private void OnClickCell(Cell cell)
    {
        if (screen.dialogs.Count == 0)
        {
            bool handled = false;
            MenuBar? menuBar = screen.menuBar;
            if (menuBar != null && menuBar.visible)
                handled = menuBar.Click(cell.x, cell.y);

            if (!handled)
                screen.topContainer.Click(cell.x, cell.y);
        }
        else
        {
            Dialog dialog = screen.dialogs[^1];
            dialog.Click((short)(cell.x - dialog.X), (short)(cell.y - dialog.Y));
        }

        screen.Render();
    }

    public void Dispose()
    {
        _disposed = true;
        _timer.Enabled = false;
        _timer.Elapsed -= TimeElapsed;
        _timer.Dispose();
    }
}
