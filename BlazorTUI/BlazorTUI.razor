@using global::BlazorTUI.TUI
@using Microsoft.JSInterop

@implements IDisposable
@inject IJSRuntime JSRuntime

<div class="containerfs">
    <span id="@InstructionsId" class="blazortui-visually-hidden">@EffectiveKeyboardInstructions</span>
    @if (!string.IsNullOrWhiteSpace(AriaDescription))
    {
        <span id="@DescriptionId" class="blazortui-visually-hidden">@AriaDescription</span>
    }
    <pre id="@ScreenTextId" class="blazortui-visually-hidden">@AccessibleScreenText</pre>
    <div id="@ControlSummariesId" class="blazortui-visually-hidden" aria-label="Control summaries">@SemanticControlText</div>
    <span class="blazortui-visually-hidden" role="status" aria-live="polite" aria-atomic="true">@AccessibilityStatusText</span>
    <span class="blazortui-visually-hidden" role="status" aria-live="polite" aria-atomic="true">@_focusAnnouncement</span>

    <div @ref="_gridElement"
         tabindex="0"
         class="gridfs"
         style="@GridCssVariables"
         role="application"
         aria-label="@AriaLabel"
         aria-roledescription="text user interface"
         aria-describedby="@DescriptionIds"
         aria-keyshortcuts="@AriaKeyShortcuts"
         data-shortcuts="@ShortcutDescriptorsJson"
         data-clipboard-enabled="@(ActiveClipboardControl is not null ? "true" : "false")"
         data-clipboard-copy-enabled="@(ClipboardCopyEnabled ? "true" : "false")"
         data-clipboard-paste-enabled="@(ClipboardPasteEnabled ? "true" : "false")"
         data-edit-history-enabled="@(ActiveUndoableControl is not null ? "true" : "false")"
         data-tab-navigation-enabled="@(ActiveTabControl is not null ? "true" : "false")"
         data-command-palette-enabled="@(ActiveCommandPalette is not null ? "true" : "false")"
         @onkeydown="HandleKeyDown"
         @onmouseleave="OnGridMouseLeave">
        @foreach (Row row in Screen.Rows)
        {
            <TuiRow @key="row"
                    Row="row"
                    CellClicked="OnClickCell"
                    CellMouseDown="OnCellMouseDown"
                    CellMouseMove="OnCellMouseMove"
                    CellMouseUp="OnCellMouseUp"
                    CellContextClicked="OnContextClickCell" />
        }
    </div>
</div>

@code {
    [Parameter]
    public Screen Screen { get; set; } = null!;

    [Parameter]
    public string AriaLabel { get; set; } = "Text user interface";

    [Parameter]
    public string? AriaDescription { get; set; }

    [Parameter]
    public string? KeyboardInstructions { get; set; }

    public IReadOnlyList<string> FocusHistoryAnnouncements => _focusHistoryAnnouncements;

    private readonly System.Timers.Timer _timer = new(250);
    private readonly string _accessibilityId = $"blazortui-{Guid.NewGuid():N}";
    private ElementReference _gridElement;
    private DotNetObjectReference<BlazorTUI>? _componentReference;
    private Screen? _renderedScreen;
    private IClipboardControl? _renderedClipboardControl;
    private bool _renderedClipboardCopyEnabled;
    private bool _renderedClipboardPasteEnabled;
    private IUndoableControl? _renderedUndoableControl;
    private TabControl? _renderedTabControl;
    private CommandPalette? _renderedCommandPalette;
    private long _renderedRevision = -1;
    private string _renderedSemanticControlText = "";
    private string _focusAnnouncement = "";
    private string _renderedFocusAnnouncement = "";
    private string? _announcedFocusControlName;
    private readonly List<string> _focusHistoryAnnouncements = new();
    private Screen? _accessibleScreen;
    private long _accessibleRevision = -1;
    private string _accessibleScreenText = "";
    private TuiDragSession? _dragSession;
    private short _dragStartScreenX;
    private short _dragStartScreenY;
    private short _lastDragScreenX;
    private short _lastDragScreenY;
    private bool _suppressNextClick;
    private bool _disposed;

    private string InstructionsId => $"{_accessibilityId}-instructions";

    private string DescriptionId => $"{_accessibilityId}-description";

    private string ScreenTextId => $"{_accessibilityId}-screen";

    private string ControlSummariesId => $"{_accessibilityId}-controls";

    private string DescriptionIds
        => string.IsNullOrWhiteSpace(AriaDescription)
            ? $"{InstructionsId} {ScreenTextId} {ControlSummariesId}"
            : $"{InstructionsId} {DescriptionId} {ScreenTextId} {ControlSummariesId}";

    private string EffectiveKeyboardInstructions
        => KeyboardInstructions ?? BuildKeyboardInstructions();

    private string AriaKeyShortcuts
        => string.Join(
            " ",
            Screen.Shortcuts
                .ToAriaKeyShortcuts()
                .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .Concat([
                    "ArrowUp",
                    "ArrowDown",
                    "ArrowLeft",
                    "ArrowRight",
                    "Enter",
                    "Space",
                    "Escape",
                    "F4",
                    "Backspace",
                    "Delete",
                    "Home",
                    "End",
                    "PageUp",
                    "PageDown"
                ])
                .Distinct(StringComparer.OrdinalIgnoreCase));

    private string ShortcutDescriptorsJson
        => System.Text.Json.JsonSerializer.Serialize(Screen.Shortcuts.GetDescriptors());

    private string AccessibleScreenText
    {
        get
        {
            if (!ReferenceEquals(_accessibleScreen, Screen) || _accessibleRevision != Screen.Revision)
            {
                _accessibleScreenText = string.Join(
                    Environment.NewLine,
                    Screen.Rows.Select(row => string.Concat(row.ReadOnlyCells.Select(cell => cell.IsVisible ? cell.Character : "")).TrimEnd()))
                    .TrimEnd();
                _accessibleScreen = Screen;
                _accessibleRevision = Screen.Revision;
            }

            return _accessibleScreenText;
        }
    }

    private string SemanticControlText
        => Screen is null
            ? ""
            : string.Join(Environment.NewLine, EnumerateAccessibilitySummaries());

    private string AccessibilityStatusText
    {
        get
        {
            if (Screen.Dialogs.Count > 0)
                return $"Dialog opened: {Screen.Dialogs[^1].Title}";

            Menu? openMenu = Screen.MenuBar?.OpenMenu;
            if (openMenu is not null)
                return $"Menu opened: {openMenu.Text}";

            if (ActiveCommandPalette is { IsOpen: true } commandPalette)
                return $"Command palette opened: {commandPalette.Title}";

            return ActiveTabControl?.SelectedTab is { } selectedTab
                ? $"Tab selected: {selectedTab.Title}"
                : "";
        }
    }

    private IClipboardControl? ActiveClipboardControl
    {
        get
        {
            Container activeContainer = Screen.Dialogs.Count == 0 ? Screen.TopContainer : Screen.Dialogs[^1];
            return activeContainer.GetCurrentFocusControl() as IClipboardControl;
        }
    }

    private IUndoableControl? ActiveUndoableControl
    {
        get
        {
            Container activeContainer = Screen.Dialogs.Count == 0 ? Screen.TopContainer : Screen.Dialogs[^1];
            return activeContainer.GetCurrentFocusControl() as IUndoableControl;
        }
    }

    private bool ClipboardCopyEnabled
        => ActiveClipboardControl is { } control &&
            control is not IClipboardPermissions { AllowCopy: false };

    private bool ClipboardPasteEnabled
        => ActiveClipboardControl is { } control &&
            control is not IClipboardPermissions { AllowPaste: false };

    private TabControl? ActiveTabControl
    {
        get
        {
            Container activeContainer = Screen.Dialogs.Count == 0 ? Screen.TopContainer : Screen.Dialogs[^1];
            Container? currentContainer = activeContainer.GetCurrentFocusControl()?.ParentContainer;
            while (currentContainer is not null)
            {
                if (currentContainer is TabControl tabControl)
                    return tabControl;

                currentContainer = currentContainer.Parent;
            }

            return FindKeyboardActiveTabControl(activeContainer);
        }
    }

    private CommandPalette? ActiveCommandPalette
    {
        get
        {
            Container activeContainer = Screen.Dialogs.Count == 0 ? Screen.TopContainer : Screen.Dialogs[^1];
            return FindCommandPalette(activeContainer);
        }
    }

    private static CommandPalette? FindCommandPalette(Container container)
    {
        CommandPalette? firstVisible = null;

        foreach (Control control in container.Controls.Where(control => control.Visible))
        {
            if (control is not CommandPalette commandPalette)
                continue;

            if (commandPalette.IsOpen)
                return commandPalette;

            firstVisible ??= commandPalette;
        }

        foreach (Container child in container.Containers.Where(child => child.Visible))
        {
            CommandPalette? commandPalette = FindCommandPalette(child);
            if (commandPalette?.IsOpen == true)
                return commandPalette;

            firstVisible ??= commandPalette;
        }

        return firstVisible;
    }

    private static TabControl? FindKeyboardActiveTabControl(Container container)
    {
        if (container is TabControl { IsKeyboardActive: true } tabControl)
            return tabControl;

        foreach (Container child in container.Containers.Where(child => child.Visible))
        {
            if (FindKeyboardActiveTabControl(child) is { } activeTabControl)
                return activeTabControl;
        }

        return null;
    }

    private string GridCssVariables
    {
        get
        {
            double width = Math.Max(1d, Screen.Width);
            double height = Math.Max(1d, Screen.Height);
            double aspectRatio = width / (height * 2);
            double inverseAspectRatio = 1 / aspectRatio;
            double fontSize = 100 / height;

            return FormattableString.Invariant($"--tui-columns:{Screen.Width}; --tui-rows:{Screen.Height}; --tui-width-from-height:{aspectRatio * 100}cqh; --tui-height-from-width:{inverseAspectRatio * 100}cqw; --tui-font-size:{fontSize}cqh;");
        }
    }

    protected override void OnInitialized()
    {
        _timer.Elapsed += TimeElapsed;
        _timer.AutoReset = true;
        _timer.Enabled = true;
    }

    protected override void OnParametersSet()
        => Screen.Render();

    protected override bool ShouldRender()
        => !ReferenceEquals(_renderedScreen, Screen) ||
            _renderedRevision != Screen.Revision ||
            _renderedSemanticControlText != SemanticControlText ||
            _renderedFocusAnnouncement != _focusAnnouncement ||
            !ReferenceEquals(_renderedClipboardControl, ActiveClipboardControl) ||
            _renderedClipboardCopyEnabled != ClipboardCopyEnabled ||
            _renderedClipboardPasteEnabled != ClipboardPasteEnabled ||
            !ReferenceEquals(_renderedUndoableControl, ActiveUndoableControl) ||
            !ReferenceEquals(_renderedTabControl, ActiveTabControl) ||
            !ReferenceEquals(_renderedCommandPalette, ActiveCommandPalette);

    protected override void OnAfterRender(bool firstRender)
    {
        _renderedScreen = Screen;
        _renderedRevision = Screen.Revision;
        _renderedSemanticControlText = SemanticControlText;
        _renderedFocusAnnouncement = _focusAnnouncement;
        _renderedClipboardControl = ActiveClipboardControl;
        _renderedClipboardCopyEnabled = ClipboardCopyEnabled;
        _renderedClipboardPasteEnabled = ClipboardPasteEnabled;
        _renderedUndoableControl = ActiveUndoableControl;
        _renderedTabControl = ActiveTabControl;
        _renderedCommandPalette = ActiveCommandPalette;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _componentReference = DotNetObjectReference.Create(this);
        await using IJSObjectReference module = await JSRuntime.InvokeAsync<IJSObjectReference>(
            "import",
            "./_content/BlazorTUI/blazorTui.js");
        await module.InvokeVoidAsync("attachKeyboardHandling", _gridElement, _componentReference);
    }

    [JSInvokable("BlazorTUISelectAll")]
    public void SelectAllForClipboard()
    {
        if (ActiveClipboardControl is not { } control)
            return;

        control.SelectAll();
        RenderAfterControlChange();
    }

    [JSInvokable("BlazorTUICopySelection")]
    public string? CopySelectionForClipboard()
    {
        IClipboardControl? control = ActiveClipboardControl;
        return control is { HasSelection: true } && ClipboardCopyEnabled ? control.SelectedText : null;
    }

    [JSInvokable("BlazorTUICutSelection")]
    public void CutSelectionForClipboard()
    {
        if (ActiveClipboardControl is not { HasSelection: true } control || !ClipboardCopyEnabled)
            return;

        control.CutSelection();
        RenderAfterControlChange();
    }

    [JSInvokable("BlazorTUIPaste")]
    public void PasteFromClipboard(string value)
    {
        ArgumentNullException.ThrowIfNull(value);
        if (ActiveClipboardControl is not { } control || !ClipboardPasteEnabled)
            return;

        control.Paste(value);
        RenderAfterControlChange();
    }

    [JSInvokable("BlazorTUIUndo")]
    public void UndoTextEdit()
    {
        if (ActiveUndoableControl?.Undo() == true)
            RenderAfterControlChange();
    }

    [JSInvokable("BlazorTUIRedo")]
    public void RedoTextEdit()
    {
        if (ActiveUndoableControl?.Redo() == true)
            RenderAfterControlChange();
    }

    [JSInvokable("BlazorTUIMoveTab")]
    public void MoveTab(bool previous)
    {
        if (ActiveTabControl is not { } tabControl)
            return;

        if (previous)
            tabControl.SelectPreviousTab();
        else
            tabControl.SelectNextTab();

        RenderAfterControlChange(updateFocusAnnouncement: true);
    }

    [JSInvokable("BlazorTUIToggleCommandPalette")]
    public void ToggleCommandPalette()
    {
        if (ActiveCommandPalette is not { } commandPalette)
            return;

        commandPalette.Toggle();
        RenderAfterControlChange();
    }

    [JSInvokable("BlazorTUIHandleShortcut")]
    public void HandleShortcut(string action)
    {
        ArgumentException.ThrowIfNullOrWhiteSpace(action);
        if (!Enum.TryParse(action, out TuiShortcutAction shortcutAction))
            return;

        ExecuteShortcut(shortcutAction);
        UpdateFocusAnnouncement();
        StateHasChanged();
    }

    private void TimeElapsed(object? sender, System.Timers.ElapsedEventArgs e)
        => _ = InvokeAsync(RefreshFromTimer);

    private void RefreshFromTimer()
    {
        if (_disposed)
            return;

        long previousRevision = Screen.Revision;
        Screen.Render();

        if (Screen.Revision != previousRevision)
            StateHasChanged();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (string.IsNullOrEmpty(e.Key))
            return;

        TuiKeyGesture gesture = TuiKeyGesture.FromKeyboardEvent(e.Key, e.CtrlKey, e.ShiftKey, e.AltKey, e.MetaKey);
        if (Screen.Shortcuts.TryGetAction(gesture, out TuiShortcutAction action))
        {
            if (IsBrowserRoutedGesture(gesture))
                return;

            ExecuteShortcut(action);
            UpdateFocusAnnouncement();
            return;
        }

        if (e.CtrlKey || e.MetaKey || (e.AltKey && e.Key != "Alt"))
            return;

        Screen.KeyDown(e.Key, e.ShiftKey);
        Screen.Render();
        UpdateFocusAnnouncement();
    }

    private void ExecuteShortcut(TuiShortcutAction action)
    {
        switch (action)
        {
            case TuiShortcutAction.ToggleCommandPalette:
                ToggleCommandPalette();
                break;
            case TuiShortcutAction.SelectNextTab:
                MoveTab(previous: false);
                break;
            case TuiShortcutAction.SelectPreviousTab:
                MoveTab(previous: true);
                break;
            case TuiShortcutAction.SelectAll:
                SelectAllForClipboard();
                break;
            case TuiShortcutAction.Copy:
                _ = CopySelectionForClipboard();
                break;
            case TuiShortcutAction.Cut:
                CutSelectionForClipboard();
                break;
            case TuiShortcutAction.Paste:
                break;
            case TuiShortcutAction.Undo:
                UndoTextEdit();
                break;
            case TuiShortcutAction.Redo:
                RedoTextEdit();
                break;
            default:
                if (Screen.ExecuteShortcut(action))
                    RenderAfterControlChange(updateFocusAnnouncement: true);
                break;
        }
    }

    private static bool IsBrowserRoutedGesture(TuiKeyGesture gesture)
        => gesture.Control || gesture.Meta || (gesture.Alt && gesture.Key != "Alt");

    private string BuildKeyboardInstructions()
    {
        string focusNext = DescribeShortcut(TuiShortcutAction.FocusNext, "Tab");
        string focusPrevious = DescribeShortcut(TuiShortcutAction.FocusPrevious, "Shift+Tab");
        string commandPalette = DescribeShortcut(TuiShortcutAction.ToggleCommandPalette, "F2");
        string nextTab = DescribeShortcut(TuiShortcutAction.SelectNextTab, "Alt+PageDown");
        string previousTab = DescribeShortcut(TuiShortcutAction.SelectPreviousTab, "Alt+PageUp");

        return $"Use {focusNext} and {focusPrevious} to move between controls, " +
            $"{commandPalette} to open a command palette when available, " +
            $"{nextTab} and {previousTab} to change tab pages, " +
            "the arrow keys to navigate and adjust controls, PageUp and PageDown for large slider changes, " +
            "Enter or Space to activate controls, F4 to toggle combo boxes, and standard clipboard, undo, and redo shortcuts in text controls.";
    }

    private string DescribeShortcut(TuiShortcutAction action, string fallback)
    {
        IReadOnlyList<TuiKeyGesture> bindings = Screen.Shortcuts.GetBindings(action);
        if (bindings.Count == 0)
            return fallback;

        return string.Join(" or ", bindings.Select(gesture => gesture.ToString().Replace("Meta", "Command", StringComparison.Ordinal)));
    }

    private void RenderAfterControlChange(bool updateFocusAnnouncement = false)
    {
        Screen.Render();
        if (updateFocusAnnouncement)
            UpdateFocusAnnouncement();
        StateHasChanged();
    }

    private void OnClickCell(Cell cell)
    {
        if (_suppressNextClick)
        {
            _suppressNextClick = false;
            return;
        }

        if (Screen.Dialogs.Count == 0)
        {
            bool handled = false;
            MenuBar? menuBar = Screen.MenuBar;
            if (menuBar != null && menuBar.IsVisible)
                handled = menuBar.Click(cell.X, cell.Y);

            if (!handled)
                Screen.TopContainer.Click(cell.X, cell.Y);
        }
        else
        {
            Dialog dialog = Screen.Dialogs[^1];
            dialog.Click((short)(cell.X - dialog.X), (short)(cell.Y - dialog.Y));
        }

        Screen.Render();
        UpdateFocusAnnouncement();
    }

    private void OnCellMouseDown(Cell cell)
    {
        _dragSession = Screen.Dialogs.Count == 0
            ? Screen.TopContainer.BeginMouseDrag(cell.X, cell.Y)
            : BeginDialogMouseDrag(cell);

        if (_dragSession is null)
            return;

        _dragStartScreenX = cell.X;
        _dragStartScreenY = cell.Y;
        _lastDragScreenX = cell.X;
        _lastDragScreenY = cell.Y;
        _suppressNextClick = false;
        RenderAfterControlChange(updateFocusAnnouncement: true);
    }

    private void OnCellMouseMove(Cell cell)
    {
        if (_dragSession is null)
            return;

        if (cell.X == _lastDragScreenX && cell.Y == _lastDragScreenY)
            return;

        _lastDragScreenX = cell.X;
        _lastDragScreenY = cell.Y;
        if (cell.X != _dragStartScreenX || cell.Y != _dragStartScreenY)
            _dragSession.HasMoved = true;

        if (_dragSession.Drag(cell.X, cell.Y))
            RenderAfterControlChange(updateFocusAnnouncement: true);
    }

    private void OnCellMouseUp(Cell cell)
    {
        if (_dragSession is null)
            return;

        TuiDragSession session = _dragSession;
        _dragSession = null;
        _suppressNextClick = session.HasMoved;

        if (session.EndDrag(cell.X, cell.Y))
            RenderAfterControlChange(updateFocusAnnouncement: true);
    }

    private void OnGridMouseLeave()
    {
        if (_dragSession is null)
            return;

        _suppressNextClick = _dragSession.HasMoved;
        _dragSession = null;
    }

    private TuiDragSession? BeginDialogMouseDrag(Cell cell)
    {
        Dialog dialog = Screen.Dialogs[^1];
        return dialog.BeginMouseDrag(
            (short)(cell.X - dialog.X),
            (short)(cell.Y - dialog.Y));
    }

    private void OnContextClickCell(Cell cell)
    {
        if (Screen.Dialogs.Count == 0)
        {
            Screen.TopContainer.ContextClick(cell.X, cell.Y);
        }
        else
        {
            Dialog dialog = Screen.Dialogs[^1];
            dialog.ContextClick((short)(cell.X - dialog.X), (short)(cell.Y - dialog.Y));
        }

        Screen.Render();
        UpdateFocusAnnouncement();
    }

    private IEnumerable<string> EnumerateAccessibilitySummaries()
    {
        foreach (string summary in EnumerateContainerAccessibilitySummaries(Screen.TopContainer))
            yield return summary;

        foreach (Dialog dialog in Screen.Dialogs)
        {
            foreach (string summary in EnumerateContainerAccessibilitySummaries(dialog))
                yield return summary;
        }
    }

    private static IEnumerable<string> EnumerateContainerAccessibilitySummaries(Container container)
    {
        if (!container.Visible)
            yield break;

        string containerSummary = container.GetAccessibilitySummary();
        if (!string.IsNullOrWhiteSpace(containerSummary))
            yield return containerSummary;

        foreach (Control control in container.Controls
            .Where(control => control.Visible)
            .OrderBy(control => control.TabIndex)
            .ThenBy(control => control.Name, StringComparer.Ordinal))
        {
            string summary = control.GetAccessibilitySummary();
            if (!string.IsNullOrWhiteSpace(summary))
                yield return summary;
        }

        foreach (Container child in container.Containers
            .Where(child => child.Visible)
            .OrderBy(child => child.ZOrder)
            .ThenBy(child => child.Name, StringComparer.Ordinal))
        {
            foreach (string summary in EnumerateContainerAccessibilitySummaries(child))
                yield return summary;
        }
    }

    private void UpdateFocusAnnouncement()
    {
        Control? focusedControl = GetActiveContainer().GetCurrentFocusControl();
        string? focusedControlName = focusedControl?.Name;
        if (string.Equals(focusedControlName, _announcedFocusControlName, StringComparison.Ordinal))
            return;

        _announcedFocusControlName = focusedControlName;
        if (focusedControl is null)
        {
            _focusAnnouncement = "Focus cleared.";
            AddFocusHistoryAnnouncement(_focusAnnouncement);
            return;
        }

        _focusAnnouncement = $"Focus moved to {focusedControl.GetAccessibilitySummary()}";
        AddFocusHistoryAnnouncement(_focusAnnouncement);
    }

    private Container GetActiveContainer()
        => Screen.Dialogs.Count == 0 ? Screen.TopContainer : Screen.Dialogs[^1];

    private void AddFocusHistoryAnnouncement(string announcement)
    {
        if (string.IsNullOrWhiteSpace(announcement))
            return;

        _focusHistoryAnnouncements.Add(announcement);
        const int maximumAnnouncements = 20;
        if (_focusHistoryAnnouncements.Count > maximumAnnouncements)
            _focusHistoryAnnouncements.RemoveAt(0);
    }

    public void Dispose()
    {
        _disposed = true;
        _timer.Enabled = false;
        _timer.Elapsed -= TimeElapsed;
        _timer.Dispose();
        _componentReference?.Dispose();
    }
}
